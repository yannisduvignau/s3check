# --- Security (CRITICAL) ---
# Stores sensitive credentials - NEVER commit this file to Git
.env
*.pem
*.key
*_secret_*
*-secret-*

# Config files with credentials (user-generated)
s3check_*.json
!examples/*.json

# --- Python ---
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

